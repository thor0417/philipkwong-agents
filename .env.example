# Copy this file to .env.local and fill in REAL values.
# .env.local is gitignored and must never be committed.

# ── Server-side (agents only) ─────────────────────────────
# Full-access secrets. Never expose to the browser.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxx

# Intake agent — Gmail OAuth2. Paths to the OAuth client JSON (downloaded from
# Google Cloud Console) and the token cache the agent creates on first consent.
# Both files are gitignored. Defaults match these values if unset.
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./token.json

# Adzuna source (free: register at https://developer.adzuna.com/).
# Optional — if unset, the lead scraper skips Adzuna and uses CanadaBuys only.
ADZUNA_APP_ID=xxxxxxxx
ADZUNA_APP_KEY=xxxxxxxxxxxxxxxx
# Optional location filter. Defaults to "British Columbia". Set empty for Canada-wide.
ADZUNA_WHERE=British Columbia

# ── Client-side (dashboard) ───────────────────────────────
# Anon key is safe to ship to the browser; RLS protects the data.
# For local dashboard dev these also need to live in dashboard/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx
