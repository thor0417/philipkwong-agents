# Copy this file to .env.local and fill in REAL values.
# .env.local is gitignored and must never be committed.

# ── Server-side (agents only) ─────────────────────────────
# Full-access secrets. Never expose to the browser.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxx

# ── Client-side (dashboard) ───────────────────────────────
# Anon key is safe to ship to the browser; RLS protects the data.
# For local dashboard dev these also need to live in dashboard/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx
